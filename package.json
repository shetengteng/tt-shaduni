{
  "name": "tt-shaduni",
  "version": "1.0.0",
  "description": "A shadcn-style UniApp Vue3 component library",
  "main": "dist/lib/index.cjs",
  "module": "dist/es/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/es/index.mjs",
      "require": "./dist/lib/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./es/*": "./dist/es/*",
    "./lib/*": "./dist/lib/*",
    "./resolver": {
      "import": "./dist/es/resolver/index.mjs",
      "require": "./dist/lib/resolver/index.cjs",
      "types": "./dist/types/resolver/index.d.ts"
    },
    "./styles/*": "./packages/styles/*",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "files": [
    "dist",
    "packages",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build --config build/vite.lib.ts",
    "build:dts": "vue-tsc --declaration --emitDeclarationOnly --outDir dist/types -p tsconfig.build.json",
    "build:all": "npm run build && npm run build:dts",
    "build:uni_modules": "node scripts/gen-uni-modules.mjs",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "lint": "eslint packages/ --ext .ts,.vue",
    "docs:playground": "cd playground && npm run build:h5 && rm -rf ../docs/playground && cp -r dist/build/h5 ../docs/playground && cp -r static/svg ../docs/playground/static/svg",
    "release": "node scripts/release.mjs",
    "icons:extract": "node scripts/extract-icons.mjs",
    "prepublishOnly": "npm run build:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shetengteng/tt-shaduni.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/shetengteng/tt-shaduni/issues"
  },
  "homepage": "https://github.com/shetengteng/tt-shaduni#readme",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "remixicon": "^4.9.1",
    "vitest": "^4.1.3",
    "vue": "^3.5.32"
  }
}
